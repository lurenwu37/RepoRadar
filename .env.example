# GitHub Hot Repositories Radar configuration template
# Copy this file to '.env' and fill in your actual values.

# 1. Feishu Bot Webhook (Required)
# If you have a single webhook, use FEISHU_WEBHOOK_URL.
# If you have multiple webhooks to push to, separate them with commas in FEISHU_WEBHOOK_URLS.
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx
# FEISHU_WEBHOOK_URLS=url1,url2

# 2. Agnes LLM Provider API Settings (Required)
# Compatible with OpenAI Chat Completions standard format.
AGNES_API_KEY=your-agnes-api-key
AGNES_API_BASE=https://api.deepseek.com/v1
AGNES_MODEL=deepseek-chat

# 3. GitHub API Personal Access Token (Optional but highly recommended)
# Used to bypass the rate limit of 60 requests per hour for unauthorized users.
# Only requires basic public_repo read permission.
GITHUB_TOKEN=your-github-personal-access-token
